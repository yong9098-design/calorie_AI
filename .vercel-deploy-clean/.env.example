SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API 키 설정
# GEMINI_API_KEY_FLASH: Flash 모델(gemini-2.5-flash) 전용 키
# GEMINI_API_KEY_PRO:   Pro 모델(gemini-2.5-pro) 전용 키
# Pro 키가 없으면 Flash 키로 폴백됩니다.
GEMINI_API_KEY_FLASH=your_gemini_api_key_for_flash
GEMINI_API_KEY_PRO=your_gemini_api_key_for_pro
